# PostgreSQL
POSTGRES_USER=pet_postgres
POSTGRES_PASSWORD=postgres123

# Keycloak
KEYCLOAK_ADMIN=pet_keycloak
KEYCLOAK_ADMIN_PASSWORD=keyckoak123

# Kafka (bootstrap servers for Spring Boot services)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Grafana
GRAFANA_PASSWORD=grafana123

# Vault (dev mode only)
VAULT_TOKEN=my-local-token

# Spring Boot services (set in IDE run configuration)
# SPRING_PROFILES_ACTIVE=local
# VAULT_HOST=localhost
# EUREKA_HOST=localhost

# Values to store in Vault via vault-init.sh
DATA_SOURCE_URL=jdbc:postgresql://postgres-app:5432/petadoption
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=pet-adoption
KEYCLOAK_ADMIN_CLIENT_ID=pet-adoption-admin
KEYCLOAK_GATEWAY_CLIENT_ID=pet-adoption-gateway
# keycloak-admin-client-secret and keycloak-client-secret are fetched automatically by keycloak-init.sh
